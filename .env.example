# Налаштування бази даних MongoDB
MONGO_INITDB_ROOT_USERNAME=kyrsova_user
MONGO_INITDB_ROOT_PASSWORD=kyrsova_password
MONGO_INITDB_DATABASE=kpp_control

# Налаштування серверної частини
NODE_ENV=production
PORT=5000
MONGODB_URI=mongodb://kyrsova_user:kyrsova_password@db:27017/kpp_control?authSource=admin
JWT_SECRET=your-super-secret-jwt-key-change-in-production-please

# Налаштування клієнтської частини
REACT_APP_API_URL=http://localhost:5000

# Порти для доступу до сервісів
CLIENT_PORT=3000
SERVER_PORT=5000
DB_PORT=27017