# Railway Environment Variables для Production

# Дані підключення до MongoDB (Railway надасть автоматично)
MONGODB_URI=mongodb://localhost:27017/kpp_control

# JWT Secret - замініть на випадковий рядок
JWT_SECRET=your_super_secret_jwt_key_here_2024_change_this_in_production

# Налаштування сервера
NODE_ENV=production
PORT=5000

# CORS налаштування - Railway надасть домен автоматично
CORS_ORIGIN=https://your-app.railway.app

# Опціональні налаштування
LOG_LEVEL=info
SESSION_TIMEOUT=3600

# Налаштування безпеки
BCRYPT_ROUNDS=12
JWT_EXPIRY=24h

# Для локальної розробки
REACT_APP_API_URL=http://localhost:5000