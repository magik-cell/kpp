# Локальна розробка - Налаштування середовища

# Дані підключення до локальної MongoDB
MONGODB_URI=mongodb://localhost:27017/kpp_control

# JWT Secret - замініть на випадковий рядок
JWT_SECRET=your_super_secret_jwt_key_here_2024_change_this

# Налаштування сервера
NODE_ENV=development
PORT=5000

# CORS налаштування для локальної розробки
CORS_ORIGIN=http://localhost:3000

# Налаштування безпеки
BCRYPT_ROUNDS=10
JWT_EXPIRY=24h

# Клієнтська частина
REACT_APP_API_URL=http://localhost:5000/api