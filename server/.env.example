# Server Environment Variables для Railway

# MongoDB підключення - Railway автоматично встановить
MONGODB_URI=mongodb://localhost:27017/kpp_control

# JWT налаштування
JWT_SECRET=your_super_secret_jwt_key_here_2024_change_this_in_production
JWT_EXPIRY=24h

# Server налаштування
NODE_ENV=production
PORT=5000

# CORS налаштування
CORS_ORIGIN=https://your-app.railway.app

# Безпека
BCRYPT_ROUNDS=12

# Логи
LOG_LEVEL=info