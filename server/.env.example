# Server Environment Variables для локальної розробки

# MongoDB підключення до локальної бази
MONGODB_URI=mongodb://localhost:27017/kpp_control

# JWT налаштування
JWT_SECRET=your_super_secret_jwt_key_here_2024_change_this
JWT_EXPIRY=24h

# Server налаштування
NODE_ENV=development
PORT=5000

# CORS налаштування
CORS_ORIGIN=http://localhost:3000

# Безпека
BCRYPT_ROUNDS=10